# --- App ---
NODE_ENV=development
PORT=4000
# Public URL for links in emails. Must match EXPO_PUBLIC_API_BASE_URL in the Frontend .env
# so verification links and the app hit the same backend/database.
API_BASE_URL=http://localhost:4000
CORS_ORIGIN=*

# --- Database (PostgreSQL) ---
# Local:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/mallorca_dating
#   DATABASE_SSL=false
#
# Supabase (Node.js API — prefer Session pooler on port 5432, not 6543):
#   DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#   DATABASE_SSL=true
#
# If you must use the transaction pooler (port 6543), add ?pgbouncer=true to the URL.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/mallorca_dating
DATABASE_SSL=false

# --- JWT ---
JWT_ACCESS_SECRET=replace_with_strong_random_string
JWT_REFRESH_SECRET=replace_with_another_strong_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Email (verification, password reset, etc.) ---
# Use the official company mailbox for SMTP auth and the From header.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=info@citasmallorca.es
SMTP_PASS=changeme
MAIL_FROM="Citas Mallorca <info@citasmallorca.es>"

# --- AWS S3 / Cloudflare R2 ---
STORAGE_PROVIDER=s3
S3_BUCKET=mallorca-dating-uploads
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# --- Firebase (FCM) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Google Play (server-side purchase validation) ---
GOOGLE_PLAY_PACKAGE_NAME=es.citasmallorca.app
GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Google Sign-In (verify mobile ID tokens) ---
# Use the Web application OAuth client ID (same value as EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID).
GOOGLE_CLIENT_ID=
# Optional iOS OAuth client ID (same value as EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID).
GOOGLE_IOS_CLIENT_ID=

# Set to "true" ONLY in dev/staging to allow Premium activation without a
# real Google Play purchase. Production must always leave this unset/false.
BILLING_ALLOW_MOCK=false

# --- Public site & contact ---
PUBLIC_WEB_URL=https://www.citasmallorca.es
# Custom URL scheme for returning to the mobile app after email verification.
APP_DEEP_LINK_SCHEME=citasmallorca
CONTACT_INFO_EMAIL=info@citasmallorca.es
CONTACT_SUPPORT_EMAIL=info@citasmallorca.es

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Admin ---
ADMIN_EMAILS=admin@citasmallorca.es
