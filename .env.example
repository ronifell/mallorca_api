# --- App ---
NODE_ENV=development
PORT=4000
# Public URL for links in emails and local photo URLs. When testing on a phone,
# set this to your PC LAN IP (same host as EXPO_PUBLIC_API_BASE_URL), not localhost.
API_BASE_URL=http://localhost:4000
CORS_ORIGIN=*

# --- Database (PostgreSQL) ---
# Local:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5432/mallorca_dating
#   DATABASE_SSL=false
#
# Supabase (Node.js API — prefer Session pooler on port 5432, not 6543):
#   DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
#   DATABASE_SSL=true
#
# If you must use the transaction pooler (port 6543), add ?pgbouncer=true to the URL.

DATABASE_URL=postgres://postgres:postgres@localhost:5432/mallorca_dating
DATABASE_SSL=false

# --- JWT ---
JWT_ACCESS_SECRET=replace_with_strong_random_string
JWT_REFRESH_SECRET=replace_with_another_strong_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Email ---
# EMAIL_PROVIDER:
#   smtp  — default; requires outbound access to SMTP_HOST:SMTP_PORT
#   log   — dev only: prints emails + verification links to the backend console
#           (use when your network blocks SMTP ports 587/465, common on home ISPs)
#   resend — production-friendly HTTPS API (works when SMTP ports are blocked)
EMAIL_PROVIDER=log
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=user@example.com
SMTP_PASS=changeme
MAIL_FROM="Citas Mallorca <no-reply@citasmallorca.es>"
# When using Gmail SMTP, the From address must match SMTP_USER (or a configured
# alias). If MAIL_FROM uses another domain, the backend sends from SMTP_USER
# automatically while keeping the display name above.
#
# Resend (EMAIL_PROVIDER=resend) — https://resend.com
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Citas Mallorca <onboarding@your-verified-domain.com>"

# --- AWS S3 / Cloudflare R2 ---
STORAGE_PROVIDER=s3
S3_BUCKET=mallorca-dating-uploads
S3_REGION=eu-west-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# --- Firebase (FCM) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# --- Google Play (server-side purchase validation) ---
GOOGLE_PLAY_PACKAGE_NAME=es.citasmallorca.app
GOOGLE_SERVICE_ACCOUNT_JSON=

# Set to "true" ONLY in dev/staging to allow Premium activation without a
# real Google Play purchase. Production must always leave this unset/false.
BILLING_ALLOW_MOCK=false

# --- Public site & contact ---
PUBLIC_WEB_URL=https://www.citasmallorca.es
CONTACT_INFO_EMAIL=info@citasmallorca.es
CONTACT_SUPPORT_EMAIL=soporte@citasmallorca.es

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# --- Admin ---
ADMIN_EMAILS=admin@citasmallorca.es
